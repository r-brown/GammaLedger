APP_ENV=local
DEBUG=false

# SQLite (local). For hosted mode, use:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/gammaledger
DATABASE_URL=sqlite+aiosqlite:///./gammaledger.db

AUTH_ENABLED=false
TENANTS_ENABLED=false

# Hosted mode only
REDIS_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MAX_TOKENS=65536
AI_EXTERNAL_CALLS_ENABLED=false
FINNHUB_API_KEY=

# Comma-separated. Empty = same-origin only.
CORS_ORIGINS=
